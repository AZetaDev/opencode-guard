{
  "name": "opencode-guard",
  "version": "0.1.0",
  "description": "Security-first fail-closed policy guard for OpenCode-style file tool execution.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AZetaDev/opencode-guard.git"
  },
  "homepage": "https://github.com/AZetaDev/opencode-guard#readme",
  "bugs": {
    "url": "https://github.com/AZetaDev/opencode-guard/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "default": "./dist/host/index.js"
    },
    "./opencode": {
      "types": "./dist/opencode/index.d.ts",
      "default": "./dist/opencode/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    }
  },
  "keywords": [
    "security",
    "plugin",
    "opencode",
    "policy",
    "guard",
    "typescript",
    "tooling"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test",
    "validate": "npm run typecheck && npm test",
    "prepack": "npm run validate",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
