{
  // Mix grouped and single-value rules to keep a policy concise.
  "version": 1,
  "defaultAction": "deny",
  "symlinkPolicy": "deny",
  "rules": [
    {
      "id": "allow-read-and-edit-docs",
      "action": "allow",
      "commands": ["read", "edit"],
      "pathPrefix": "/workspace/project/docs"
    },
    {
      "id": "allow-write-drafts",
      "action": "allow",
      "command": "write",
      "pathPrefix": "/workspace/project/docs/drafts"
    }
  ]
}
