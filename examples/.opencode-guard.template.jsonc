{
  // Schema version.
  // The current implementation supports only version 1.
  "version": 1,

  // Global fallback action.
  // This is part of the plugin's fixed protective base in the current MVP.
  // The secure MVP is intentionally fail-closed, so only "deny" is supported.
  "defaultAction": "deny",

  // Filesystem symlink handling.
  // This is also part of the fixed protective base today.
  // The current implementation supports only "deny".
  "symlinkPolicy": "deny",

  // Ordered rule list.
  // This is the main user-customizable policy layer.
  // Rules are checked from top to bottom, and the first matching rule wins.
  // Each rule must use exactly one command form and exactly one path form:
  // - command OR commands
  // - pathPrefix OR pathPrefixes
  "rules": [
    {
      // Unique rule identifier used in audit output and decision reasons.
      "id": "allow-readme-read",

      // Per-rule action.
      // Supported values are "allow" and "deny".
      "action": "allow",

      // Exact command token.
      // Examples include read, write, edit, or another lowercase host command.
      "command": "read",

      // Absolute normalized path prefix.
      // This can match a single file or a directory tree under the prefix.
      // Must start with / and must already be normalized.
      "pathPrefix": "/workspace/project/README.md"
    },
    {
      // Example grouped rule.
      // Use plural fields when one rule should cover multiple commands or path areas.
      "id": "allow-docs-read-and-edit",
      "action": "allow",
      "commands": ["read", "edit"],
      "pathPrefixes": [
        "/workspace/project/docs",
        "/workspace/project/shared"
      ]
    }
  ]
}
